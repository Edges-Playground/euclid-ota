<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/euclid_background">

    <com.euclid.ota.AnimatedBackground
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EUCLIDOS"
            android:textColor="@color/euclid_blue"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Geometry in Motion."
            android:textColor="@color/euclid_text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/checkUpdateButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Check for Updates" 
            android:textColor="#000000"
            android:textStyle="bold"
            android:backgroundTint="@color/euclid_blue"
            app:cornerRadius="28dp"
            style="@style/Widget.Material3.Button"/>
            
    </LinearLayout>
</RelativeLayout>

